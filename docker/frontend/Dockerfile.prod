# Production Dockerfile for Trinity Frontend
# Multi-stage build: npm build → nginx serving static assets

# Stage 1: Build
FROM node:24-alpine AS builder

WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies (use npm install since package-lock.json might not exist)
RUN npm install

# Copy source code
COPY . .

# Build arguments (injected at build time)
# NOTE: every VITE_* var is statically inlined into the world-readable client
# bundle by Vite at `npm run build` — never pass a secret here. Defaults mirror
# the code source-of-truth in src/components/HelpChatWidget.vue (#1116/#1489).
ARG VITE_API_URL=http://localhost:8000
ARG VITE_BUG_REPORTING_ENABLED=true
ARG VITE_BUG_INTAKE_URL=https://intake.abilityai.dev/v1/report-bug

# Set environment variables for Vite build
ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_BUG_REPORTING_ENABLED=${VITE_BUG_REPORTING_ENABLED}
ENV VITE_BUG_INTAKE_URL=${VITE_BUG_INTAKE_URL}

# Build the application
RUN npm run build

# Stage 2: Production nginx server (unprivileged variant — CSO hardening, issue #874)
FROM nginxinc/nginx-unprivileged:alpine

# nginxinc/nginx-unprivileged:alpine ends with `USER nginx` (UID 101).
# Toggle root for setup, then nginx for runtime — single pair so the
# subsequent RUN/COPY can write to /etc/nginx and /usr/share/nginx/html.
USER root

# Remove default nginx config
RUN rm /etc/nginx/conf.d/default.conf

# Copy custom nginx config and security headers include
COPY --from=builder /app/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/security-headers.conf /etc/nginx/security-headers.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Add curl for healthcheck (must be root)
RUN apk add --no-cache curl

USER nginx

# Unprivileged nginx binds 8080 (≥1024 needs no NET_BIND_SERVICE).
# Host-side port 80 mapping lives in docker-compose.prod.yml.
EXPOSE 8080

# Run nginx in foreground
CMD ["nginx", "-g", "daemon off;"]
