{
  "name": "trinity-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for orchestrating Trinity agents",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector http://localhost:8080/mcp",
    "test": "node --import tsx --test src/*.test.ts src/tools/*.test.ts"
  },
  "keywords": [
    "mcp",
    "trinity",
    "agent",
    "orchestration"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "fastmcp": "^4.7.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": ">=4.12.30",
    "axios": ">=1.18.1",
    "fast-uri": ">=4.1.0",
    "@hono/node-server": ">=2.0.10",
    "ip-address": ">=10.2.0",
    "qs": ">=6.15.3",
    "esbuild": ">=0.28.1"
  }
}
