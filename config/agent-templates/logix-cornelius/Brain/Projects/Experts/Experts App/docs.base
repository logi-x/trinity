# Live index of Experts App docs/. Grouped by area (reference/designs/guides/…),
# derived from the folder path so it never goes stale. Embed via ![[docs.base]].
filters:
  and:
    - 'file.ext == "md"'
    - 'file.inFolder("Projects/Experts/Experts App/docs")'

formulas:
  # area = first folder segment under .../Experts App/docs/ (segment index 4)
  area: 'file.folder.split("/").slice(4, 5).join("")'
  updated_ago: '(now() - file.mtime).days.round(0).toString() + "d ago"'

properties:
  file.name:
    displayName: "Doc"
  formula.area:
    displayName: "Area"
  formula.updated_ago:
    displayName: "Updated"
  file.mtime:
    displayName: "Modified"

views:
  - type: table
    name: "Active docs"
    filters:
      not:
        - 'formula.area == "_archive"'
    groupBy:
      property: formula.area
      direction: ASC
    order:
      - file.name
      - formula.updated_ago
      - file.mtime
    summaries:
      file.name: Filled

  - type: table
    name: "Archive"
    filters:
      and:
        - 'formula.area == "_archive"'
    order:
      - file.name
      - file.mtime
