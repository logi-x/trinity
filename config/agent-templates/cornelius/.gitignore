# =============================================================================
# AGENT-SPECIFIC
# =============================================================================

# Smart Connections plugin environment
.smart-env/

# Local search index + learned state (100% derived from Brain/**/*.md; rebuilt per host).
# NOTE: patterns below were top-level only and missed the real files one dir down in data/.
# Untracked 2026-06-07 to stop repo bloat + binary-merge conflicts on q_values.json/usage_history.jsonl.
resources/local-brain-search/*.faiss
resources/local-brain-search/*.pkl
resources/local-brain-search/embeddings/
resources/local-brain-search/data/
resources/brain-graph/data/

# Accidentally-committed pip download cache (~23MB) - untracked 2026-06-07
resources/local-brain-search/tmp/

# Vector-store binaries are derived/regenerable - never track NEW ones anywhere
# (guards against re-bloat via scheduled-run's `git add -A`; already-tracked
#  benchmark-memory snapshot files are unaffected - gitignore never untracks).
*.faiss
*.pkl

# Brain search daemon runtime
resources/local-brain-search/daemon.pid
resources/local-brain-search/daemon.log

# Python virtual environments
resources/pdf_env/
resources/local-brain-search/venv/
scripts/utilities/yt_transcript_venv/

# Temporary workspace files
resources/temp/
resources/scratch/

# Local archive holding pen - old/superseded files moved out of the active tree (2026-06-07)
/archive/

# Stray OS/sudo junk
.sudo_as_admin_successful

# Session-specific outputs (if not needed in version control)
# outputs/temp/
# outputs/draft/

# Temporary extraction scripts (one-off utilities)
extract_*.py
# ...but skill extraction scripts ARE part of the codebase
!.claude/skills/**/extract_*.py
list_epub_contents.py
call_abliterated.py
test_abliterated.py
final_extraction.py
run_extraction.sh
test_with_token.sh
EPUB_EXTRACTION_*.md
EXTRACTION_COMPLETE.md

# External reference folders (symlinks or copies)
Eugene Personal Brand/
.local/
content/

# Claude runtime state (ephemeral, should not be tracked)
.claude/statsig/
.claude/todos/
.claude/shell-snapshots/
.claude/stats-cache.json
.cache/

# Playwright MCP browser output (ephemeral console logs / traces)
.playwright-mcp/

# Agent-visualization derived data (100% regenerated by export_data.py from the
# Brain graph; ~11MB - same rebuild-per-host policy as the FAISS/pkl stores).
# NOTE: data.json is intentionally SHIPPED (tracked) in this bundled template —
# see the negation in the Brain Orb block above; only data.js stays ignored.
resources/agent-visualization/data.js
!resources/agent-visualization/data.json

# Raw voice session transcripts (JSONL exhaust; processed into
# Brain/00-Inbox/Voice Conversations/ by the voice-transcripts skill)
resources/agent-visualization/voice/conversations/

# Reference-scope data folders (external facts: employees, clients, contracts).
# This is a fully PRIVATE agent on a private remote, so reference data is
# COMMITTED/synced by default - no privacy gate, treated like any other note.
# (If a future scope must be host-local, add `Brain/<Scope>/` here; see
# resources/layered-brains/REFERENCE-SCOPE-SCHEMA.md "The privacy gate".)
