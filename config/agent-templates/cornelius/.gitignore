# =============================================================================
# TRINITY PLATFORM - REQUIRED EXCLUSIONS
# =============================================================================

# Credentials and secrets (NEVER commit these)
.mcp.json
.mcp.backup.json
.env
*.pem
*.key
*.p12
*.pfx

# User-specific Claude settings
.claude/settings.local.json
.claude/claude_desktop_config.json
settings.local.json

# Claude runtime state (NOT agent value - these are ephemeral)
# Agent value (.claude/skills/, rules/, agents/, commands/, memory/) MUST be tracked
.claude/debug/
.claude/projects/
.claude/cache/
.claude/credentials/

# Obsidian app settings (user-specific)
.obsidian/

# Trinity platform-managed directories.
# Re-include .trinity/ itself first: the Trinity monorepo's root .gitignore has a
# blanket `.trinity/` (dir-form) that would prune this whole tree — a deeper
# re-include of the directory (whose parent is not excluded) overrides it so the
# bundled Brain Orb convention hooks are committable in the OSS repo (ent#107).
# Star-form (not dir-form) so the committed hooks can then be re-included — git
# cannot re-include files beneath an excluded DIRECTORY (trinity-enterprise#76).
# Runtime state under brain-orb/ stays ignored via the explicit trailing rules.
!.trinity/
.trinity/*
!.trinity/setup.sh
!.trinity/brain-orb/
.trinity/brain-orb/state.json
.trinity/brain-orb/voice-postprocess.json
.trinity/brain-orb/voice-postprocess.md
.claude/commands/trinity/

# Brain Orb live export — regenerated per-agent by scope/refresh.
# In this bundled OSS template BOTH data.seed.json AND a pre-generated data.json
# ship tracked, so the orb renders end-to-end on first load with no export step
# (ent#107). The heavy binary index dirs (local-brain-search/data, brain-graph/
# data) stay ignored below. `data.js` (a JS wrapper form) stays ignored.
resources/agent-visualization/data.js
!resources/agent-visualization/data.json

