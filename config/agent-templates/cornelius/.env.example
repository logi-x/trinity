# Cornelius agent credentials — copy to .env and fill in.
# Trinity injects .env into the agent container (CRED-002); locally, Claude Code
# reads it for the MCP servers in .mcp.json.template.

# Gemini API key — powers the aistudio MCP server (content generation, Google
# Search grounding) and, on Trinity, the Brain Orb voice tile.
GEMINI_API_KEY=your-gemini-api-key

# Optional: where your Obsidian vault lives (defaults to ./Brain in this repo).
VAULT_BASE_PATH=./Brain

# Optional overrides for the ebook-mcp server (EPUB/PDF extraction).
# UV_PATH=uv
# EBOOK_MCP_PATH=/opt/mcp/ebook-mcp
